{
  "name": "@ant-design/icons-angular-workspace",
  "version": "0.0.0-NOT-VALID",
  "scripts": {
    "ng": "node scripts/ng.cjs",
    "start": "npm run ng -- serve",
    "lint": "npm run ng -- lint",
    "lint:fix": "npm run ng -- lint --fix",
    "test": "npm run ng -- test --watch=false --coverage --coverage-exclude=src/icons",
    "build": "npm run ng -- build examples --configuration production",
    "build:lib": "npm run clean && npm run generate && npm run ng -- build ant-design-icons-angular --configuration production && npm run copy:assets",
    "clean": "tsx scripts/clean.ts",
    "generate": "tsx scripts/generate.ts",
    "copy:assets": "tsx scripts/copy.ts",
    "ci": "npm run build:lib && npm run test"
  },
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@ant-design/colors": "^7.0.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@ant-design/icons-svg": "^4.0.0",
    "@types/fs-extra": "^11.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "angular-eslint": "^21.4.0",
    "eslint": "^9.27.0",
    "eslint-plugin-prettier": "~5.5.0",
    "fs-extra": "^11.0.0",
    "jsdom": "^27.2.0",
    "lodash": "^4.18.0",
    "ng-packagr": "^22.0.0",
    "prettier": "^3.8.3",
    "rxjs": "^7.8.0",
    "tsx": "^4.22.0",
    "typescript": "~6.0.0",
    "vitest": "^4.1.0"
  }
}
